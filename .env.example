# DevPilot Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Dev: skip macOS Keychain prompts (Tauri debug builds only) ───────────────
# Debug `tauri dev` builds already default to ~/.project-manager/dev-secrets.json.
# Set PM_DEV_PLAINTEXT_SECRETS=0 to force Keychain in debug, or =1 to force the dev file in release.
# PM_DEV_PLAINTEXT_SECRETS=1

# ── AI (required for browser mode) ───────────────────────────────────────────
# Used by the Next.js server-side proxy (/api/anthropic).
# In Tauri release builds the key is stored in the OS Keychain; debug tauri dev uses
# ~/.project-manager/dev-secrets.json by default. This var is ignored in Tauri mode.
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub integration (optional) ────────────────────────────────────────────
# Personal Access Token with repo read scope.
# Used by the GitHub ingestion feature.
GITHUB_TOKEN=ghp_...

# ── Local Supabase (optional — pairs with docker/supabase) ───────────────────
# After `cd docker/supabase && docker compose up -d`, sync values into .env.local:
#   npm run supabase:sync-env
#
# Or set manually (renderer-safe anon key only):
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54329
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# Ops-only (never expose to browser bundles):
# PM_BACKEND_MODE=local-docker-supabase
# PM_BACKEND_SUPABASE_URL=http://localhost:54329
# PM_BACKEND_SUPABASE_ANON_KEY=<same as NEXT_PUBLIC_SUPABASE_ANON_KEY>
# PM_BACKEND_SUPABASE_SERVICE_ROLE_KEY=<from docker/supabase/.env SERVICE_ROLE_KEY>
