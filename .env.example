# DevPilot Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Dev: skip macOS Keychain prompts (Tauri debug builds only) ───────────────
# Debug `tauri dev` builds already default to ~/.project-manager/dev-secrets.json.
# Set PM_DEV_PLAINTEXT_SECRETS=0 to force Keychain in debug, or =1 to force the dev file in release.
# PM_DEV_PLAINTEXT_SECRETS=1

# ── AI (required for browser mode) ───────────────────────────────────────────
# Used by the Next.js server-side proxy (/api/anthropic).
# In Tauri release builds the key is stored in the OS Keychain; debug tauri dev uses
# ~/.project-manager/dev-secrets.json by default. This var is ignored in Tauri mode.
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub integration (optional) ────────────────────────────────────────────
# Personal Access Token with repo read scope.
# Used by the GitHub ingestion feature.
GITHUB_TOKEN=ghp_...
