#!/usr/bin/env bash
# Fast pre-push gate. Keeps most failures local while GitHub Actions remains the
# clean-clone source of truth for PR/main protection.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

if [[ "${PM_SKIP_PRE_PUSH_VERIFY:-}" == "1" ]]; then
  echo "pre-push: skipped because PM_SKIP_PRE_PUSH_VERIFY=1"
  exit 0
fi

requires_baseline=0
while read -r local_ref _local_sha remote_ref _remote_sha; do
  if [[ "$local_ref" == "refs/heads/main" || "$remote_ref" == "refs/heads/main" ]]; then
    requires_baseline=1
  fi
done

if [[ "${PM_PRE_PUSH_BASELINE:-}" == "1" ]]; then
  requires_baseline=1
fi

if [[ "$requires_baseline" == "1" ]]; then
  echo "pre-push: main branch push detected; running npm run verify:baseline"
  npm run verify:baseline
else
  echo "pre-push: running npm run verify:quick"
  npm run verify:quick
fi
