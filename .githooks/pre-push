#!/usr/bin/env bash
# Fast pre-push gate. Runs verify:quick locally for every push; GitHub Actions
# runs the full verify:baseline on every PR and push to `main` as the clean-clone
# source of truth, so the local hook deliberately does NOT duplicate it.
# Force a full local baseline with PM_PRE_PUSH_BASELINE=1, or skip entirely with
# PM_SKIP_PRE_PUSH_VERIFY=1 (document why in the PR).
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

if [[ "${PM_SKIP_PRE_PUSH_VERIFY:-}" == "1" ]]; then
  echo "pre-push: skipped because PM_SKIP_PRE_PUSH_VERIFY=1"
  exit 0
fi

if [[ "${PM_PRE_PUSH_BASELINE:-}" == "1" ]]; then
  echo "pre-push: PM_PRE_PUSH_BASELINE=1; running npm run verify:baseline"
  npm run verify:baseline
else
  echo "pre-push: running npm run verify:quick (CI runs verify:baseline on PR/main)"
  npm run verify:quick
fi
