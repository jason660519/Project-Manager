#!/usr/bin/env bash
# Fast pre-commit gate — static-export / hydration anti-patterns only.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

if ! git diff --cached --name-only | grep -qE '\.(ts|tsx)$'; then
  exit 0
fi

echo "pre-commit: verify:static-export"
npm run verify:static-export --silent
