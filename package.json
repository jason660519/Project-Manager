{
  "name": "@project-manager/app",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "next dev --webpack -p 43187",
    "dev:turbo": "next dev --turbo -p 43187",
    "prebuild": "npm run guard:legacy-surfaces && npm run docs:site:sync",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "i18n:check": "node scripts/check-ui-i18n.mjs",
    "guard:legacy-surfaces": "node scripts/check-legacy-surfaces.mjs",
    "agents:check": "node scripts/check-agents-drift.mjs",
    "branch:check": "node scripts/check-branch-hygiene.mjs",
    "feature:kickoff": "node scripts/create-feature-checkpoint.mjs",
    "feature:resume": "node scripts/resume-feature-checkpoint.mjs",
    "bridge:typecheck": "tsc --noEmit --project ../shared-bridge/tsconfig.json",
    "standards:check": "/Users/Company-AI-App-Standards/scripts/company-standards.sh check .",
    "verify:quick": "bash scripts/verify-quick.sh",
    "verify:baseline": "bash scripts/verify-baseline.sh",
    "verify:dev-issues": "node scripts/check-next-dev-issues.mjs",
    "verify:restart-pm": "bash scripts/restart-project-manager-after-tests.sh npm run verify:baseline",
    "pm:restart": "bash start_project_manager.sh restart",
    "pm-system": "node scripts/pm-system.mjs",
    "table:sheet:audit": "node scripts/audit-table-sheets.mjs",
    "verify:static-export": "node scripts/check-static-export-hygiene.mjs",
    "githooks:install": "bash scripts/install-githooks.sh",
    "standards:fix": "/Users/Company-AI-App-Standards/scripts/company-standards.sh fix .",
    "standards:doctor": "/Users/Company-AI-App-Standards/scripts/company-standards.sh doctor .",
    "standards:report": "/Users/Company-AI-App-Standards/scripts/company-standards.sh report .",
    "standards:colors": "bash scripts/check-hard-coded-colors.sh .",
    "docs:check": "./scripts/docs-governance-check.sh",
    "docs:fix": "./scripts/docs-governance-fix.sh",
    "docs:archive": "bash -lc './scripts/docs-governance-fix.sh . archive \"$npm_config_file\"'",
    "docs:site:sync": "node scripts/sync-documentation-site.mjs",
    "docs:site:check": "node scripts/sync-documentation-site.mjs --check",
    "docs:site:watch": "node scripts/sync-documentation-site.mjs --watch",
    "hermes": "bash scripts/hermes-agent.sh",
    "hermes:install": "bash scripts/install-hermes-agent.sh",
    "hermes:doctor": "bash scripts/hermes-agent.sh doctor",
    "hermes:dashboard": "bash scripts/hermes-agent.sh dashboard --host 127.0.0.1 --port 9119 --no-open",
    "hermes:update": "bash scripts/update-hermes-agent.sh",
    "hermes:rollback": "bash scripts/rollback-hermes-agent.sh",
    "openclaw": "bash scripts/openclaw.sh",
    "openclaw:install": "bash scripts/install-openclaw.sh",
    "openclaw:doctor": "bash scripts/openclaw.sh doctor",
    "openclaw:gateway": "bash scripts/openclaw.sh gateway --port 18790 --verbose",
    "openclaw:dashboard": "bash scripts/openclaw.sh dashboard --no-open",
    "openclaw:update": "bash scripts/update-openclaw.sh",
    "openclaw:rollback": "bash scripts/rollback-openclaw.sh",
    "openclaw:sync-env": "bash scripts/sync-openclaw-env.sh",
    "discovery:install-nmap": "bash scripts/install-nmap.sh",
    "discovery:doctor": "bash scripts/discovery-doctor.sh",
    "test": "vitest run",
    "test:restart-pm": "bash scripts/restart-project-manager-after-tests.sh npm test",
    "test:watch": "vitest",
    "e2e:tauri:f34-select": "node scripts/run-f34-tauri-select-e2e.mjs",
    "e2e:pilot:smoke": "node scripts/run-tauri-pilot-e2e.mjs --suite smoke",
    "e2e:pilot": "node scripts/run-tauri-pilot-e2e.mjs",
    "eval:run:wrapper": "node eval/runners/run-wrapper-batch.mjs --help",
    "eval:run:wrapper-example": "node eval/runners/run-wrapper-batch-example.mjs --dataset eval/datasets/llm-sample-tasks.v1.json --output eval/runs/run-rows.jsonl --model demo-model --provider demo-provider --trials 3",
    "eval:run:raw-api": "node eval/runners/run-raw-api-batch.mjs --help",
    "eval:benchmark:all": "node eval/runners/run-benchmark-all.mjs --help",
    "eval:benchmark:vlm": "node eval/runners/run-benchmark-all.mjs --arena vlm --help",
    "eval:import:interactive": "node eval/runners/import-interactive-app-log.mjs --input eval/interactive/interactive-app-log.sample.jsonl --output eval/runs/run-rows.jsonl",
    "eval:adapter:openai": "node eval/runners/adapters/openai-responses-adapter.mjs --help",
    "eval:adapter:anthropic": "node eval/runners/adapters/anthropic-messages-adapter.mjs --help",
    "eval:adapter:gemini": "node eval/runners/adapters/gemini-generate-content-adapter.mjs --help",
    "eval:adapter:judge-openai": "node eval/runners/adapters/openai-judge-adapter.mjs --help",
    "eval:adapter:judge-anthropic": "node eval/runners/adapters/anthropic-judge-adapter.mjs --help",
    "eval:adapter:judge-gemini": "node eval/runners/adapters/gemini-judge-adapter.mjs --help",
    "eval:adapter:judge-mock": "node eval/runners/adapters/mock-judge-adapter.mjs --prompt \"judge this output\"",
    "eval:aggregate": "node eval/scoring/aggregate-runs.mjs --input eval/runs/run-rows.jsonl --output eval/reports/arena-report.v1.json --profile balanced_default",
    "eval:auto-score": "node eval/scoring/auto-score-rows.mjs --input eval/runs/run-rows.jsonl --dataset eval/datasets/llm-sample-tasks.v1.json --output eval/runs/run-rows.scored.jsonl",
    "eval:judge-human": "node eval/scoring/judge-human-rows.mjs --input eval/runs/run-rows.scored.jsonl --dataset eval/datasets/llm-sample-tasks.v1.json --promptDir eval/prompts --promptVersion v1 --command 'node eval/runners/adapters/mock-judge-adapter.mjs --prompt \"{{prompt}}\"' --output eval/runs/run-rows.judged.jsonl",
    "eval:summary": "node eval/scoring/report-to-markdown.mjs --input eval/reports/arena-report.v1.json --output eval/reports/arena-report.v1.md",
    "tauri:dev": "node scripts/run-tauri-dev.mjs",
    "tauri:dev:keychain": "node scripts/run-tauri-dev.mjs --keychain",
    "tauri:build": "node scripts/check-release-secrets.mjs && tauri build",
    "tauri:icon": "tauri icon"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-table": "^8.20.5",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "tailwind-merge": "^2.5.5",
    "tauri-pty": "^0.2.1"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.10"
    }
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "mermaid": "^11.15.0",
    "playwright": "^1.60.0",
    "postcss": "^8",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
