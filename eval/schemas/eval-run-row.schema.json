{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-manager.local/eval/schemas/eval-run-row.schema.json",
  "title": "EvalRunRowV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "arena",
    "task_id",
    "task_bucket",
    "model_id",
    "provider",
    "interface",
    "trial_index",
    "timestamp_utc",
    "prompt_template_version",
    "input_hash",
    "temperature",
    "max_tokens",
    "retry_count",
    "timeout_ms",
    "latency_ms",
    "prompt_tokens",
    "completion_tokens",
    "total_tokens",
    "cost_usd",
    "quality_score",
    "compliance_score",
    "error_type",
    "human_review_required"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "arena": { "type": "string", "enum": ["llm", "vlm"] },
    "task_id": { "type": "string", "minLength": 1 },
    "task_bucket": { "type": "string", "minLength": 1 },
    "model_id": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "interface": {
      "type": "string",
      "enum": ["raw_api", "wrapper", "interactive_app"]
    },
    "trial_index": { "type": "integer", "minimum": 1 },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "prompt_template_version": { "type": "string", "minLength": 1 },
    "system_prompt_hash": { "type": ["string", "null"] },
    "input_hash": { "type": "string", "minLength": 1 },
    "output_hash": { "type": ["string", "null"] },
    "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
    "max_tokens": { "type": "integer", "minimum": 1 },
    "retry_count": { "type": "integer", "minimum": 0 },
    "timeout_ms": { "type": "integer", "minimum": 1 },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "prompt_tokens": { "type": "integer", "minimum": 0 },
    "completion_tokens": { "type": "integer", "minimum": 0 },
    "total_tokens": { "type": "integer", "minimum": 0 },
    "cost_usd": { "type": "number", "minimum": 0 },
    "quality_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "compliance_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "error_type": {
      "type": "string",
      "enum": [
        "none",
        "timeout",
        "rate_limit",
        "schema_violation",
        "tool_error",
        "other"
      ]
    },
    "error_message": { "type": ["string", "null"] },
    "human_review_required": { "type": "boolean" },
    "notes": { "type": ["string", "null"] },
    "output_text": { "type": ["string", "null"] },
    "judge_prompt_version": { "type": ["string", "null"] },
    "http_status": { "type": ["integer", "null"], "minimum": 100, "maximum": 599 },
    "endpoint": { "type": ["string", "null"] },
    "stream_mode": { "type": ["string", "null"] },
    "sdk_or_cli_version": { "type": ["string", "null"] },
    "wrapper_commit_hash": { "type": ["string", "null"] },
    "app_name": { "type": ["string", "null"] },
    "app_version": { "type": ["string", "null"] },
    "operator_id": { "type": ["string", "null"] },
    "interaction_mode": { "type": ["string", "null"] }
  }
}
