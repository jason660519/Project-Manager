{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Project Manager",
  "version": "0.1.0",
  "identifier": "io.projectmanager.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:43187",
    "beforeDevCommand": "bash scripts/next-dev-if-needed.sh",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Project Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
