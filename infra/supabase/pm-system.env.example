# PM System backend local ops environment example.
# Copy to an ignored local ops file before use. Do not commit generated values.

PM_BACKEND_PROFILE_ID=local-pm
PM_BACKEND_MODE=local-self-hosted
PM_BACKEND_SUPABASE_URL=http://127.0.0.1:8000
PM_BACKEND_SUPABASE_ANON_KEY=change-me-anon-key
PM_BACKEND_SUPABASE_SERVICE_ROLE_KEY=change-me-service-role-key
PM_BACKEND_JWT_SECRET=change-me-jwt-secret
PM_BACKEND_DATABASE_PASSWORD=change-me-database-password
PM_BACKEND_COMPOSE_PROJECT_NAME=pm-system
PM_BACKEND_SCHEMA_VERSION=1
PM_BACKEND_API_PORT=8000
PM_BACKEND_POSTGRES_PORT=5432
PM_BACKEND_STUDIO_PORT=54323
# Reserved for a future slice. The current compose scaffold does NOT start
# Storage or Realtime services, and getRequiredPortChecks() does not require
# these ports yet. They remain here as the forward port contract only.
PM_BACKEND_STORAGE_PORT=5000
PM_BACKEND_REALTIME_PORT=4000
