{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project Manager Configuration",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "description": "Schema version. Increment when making breaking changes to the config structure. Current: 10.",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "description": "Stable UUID for the project config. Required in v2+; back-filled by migration on load.",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp set when the project config was first created (v2)."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp bumped on every modification (v2)."
    },
    "updatedBy": {
      "type": "string",
      "description": "Identifier of the last editor — e.g. GitHub login or email (v2)."
    },
    "project": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "root": { "type": "string", "description": "Absolute path to project root" },
        "githubUrl": {
          "type": "string",
          "description": "GitHub repository URL used for issue and PR sync, e.g. https://github.com/owner/repo"
        },
        "defaultIDE": {
          "type": "string",
          "enum": ["Cursor", "VSCode", "Trae", "Antigravity", "Kiro"],
          "default": "Trae"
        }
      },
      "required": ["name", "root", "defaultIDE"]
    },
    "features": {
      "type": "array",
      "items": { "$ref": "#/definitions/feature" }
    },
    "engineerRoles": {
      "type": "array",
      "description": "Per-project engineer role presets injected into AI dispatches as system context.",
      "items": { "$ref": "#/definitions/engineerRole" }
    },
    "cronJobs": {
      "type": "array",
      "description": "Scheduled jobs run on a recurring interval while the app is open. Each job either runs a shell command (system cron) or dispatches an engineer role with a prompt (engineer cron). See ADR-012 for the v8 split.",
      "items": { "$ref": "#/definitions/cronJob" }
    },
    "adapters": {
      "type": "object",
      "properties": {
        "ides": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "const": "ide" },
              "targetKind": { "type": "string", "enum": ["ide"] },
              "command": { "type": "string", "description": "IDE CLI command" },
              "supports": { "type": "array", "items": { "$ref": "#/definitions/capabilityKind" }, "description": "Declared capability kinds (schema v7)." },
              "traits":   { "type": "array", "items": { "$ref": "#/definitions/adapterTrait" }, "description": "Adapter trait flags (schema v7)." }
            },
            "required": ["id", "name", "type", "command"]
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "const": "agent" },
              "targetKind": { "type": "string", "enum": ["agent-cli"] },
              "command": { "type": "string", "description": "CLI command to trigger agent" },
              "argsTemplate": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Supports {prompt}, {featureId}, {root} placeholders"
              },
              "supports": { "type": "array", "items": { "$ref": "#/definitions/capabilityKind" }, "description": "Declared capability kinds (schema v7)." },
              "traits":   { "type": "array", "items": { "$ref": "#/definitions/adapterTrait" }, "description": "Adapter trait flags (schema v7)." }
            },
            "required": ["id", "name", "type", "command", "argsTemplate"]
          }
        },
        "apps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "const": "app" },
              "targetKind": { "type": "string", "enum": ["agent-app"] },
              "command": { "type": "string", "description": "Command to open the desktop app or deep link" },
              "argsTemplate": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Supports {prompt}, {featureId}, {root} placeholders when the app target supports them"
              },
              "supports": { "type": "array", "items": { "$ref": "#/definitions/capabilityKind" }, "description": "Declared capability kinds (schema v7)." },
              "traits":   { "type": "array", "items": { "$ref": "#/definitions/adapterTrait" }, "description": "Adapter trait flags (schema v7)." }
            },
            "required": ["id", "name", "type", "command", "argsTemplate"]
          }
        }
      }
    },
    "capabilityCandidates": {
      "type": "array",
      "description": "Qualification candidates surfaced in Integrations Hub VLA/TTS/STT/Hands/Tools sheets (schema v7).",
      "items": { "$ref": "#/definitions/capabilityCandidate" }
    }
  },
  "required": ["schemaVersion", "id", "project", "features", "adapters"],
  "definitions": {
    "cronJob": {
      "type": "object",
      "properties": {
        "id":          { "type": "string" },
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "enabled":     { "type": "boolean" },
        "schedule": {
          "type": "object",
          "properties": {
            "type":  { "const": "every" },
            "value": { "type": "number", "minimum": 1 },
            "unit":  { "type": "string", "enum": ["minutes", "hours"] }
          },
          "required": ["type", "value", "unit"]
        },
        "action":     { "$ref": "#/definitions/cronAction" },
        "lastRun":    { "type": "string", "format": "date-time" },
        "lastStatus": { "type": "string", "enum": ["ok", "error"] },
        "lastError": {
          "type": "object",
          "description": "Set when lastStatus === 'error'. Classified failure reason + human-readable message (v8).",
          "properties": {
            "reason":  { "type": "string" },
            "message": { "type": "string" }
          },
          "required": ["reason", "message"]
        },
        "createdAt":  { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "enabled", "schedule", "action", "createdAt"]
    },
    "cronAction": {
      "description": "Discriminated by `type` (v8). Either a system shell command or an engineer-role dispatch.",
      "oneOf": [
        { "$ref": "#/definitions/runCommandAction" },
        { "$ref": "#/definitions/dispatchEngineerAction" }
      ]
    },
    "runCommandAction": {
      "type": "object",
      "description": "Run an arbitrary shell command (system cron). The frontend scheduler invokes the existing spawnAgent bridge.",
      "properties": {
        "type":       { "const": "run-command" },
        "command":    { "type": "string" },
        "args":       { "type": "array", "items": { "type": "string" } },
        "workingDir": { "type": "string" }
      },
      "required": ["type", "command", "args", "workingDir"]
    },
    "dispatchEngineerAction": {
      "type": "object",
      "description": "Dispatch an engineer role with an assembled prompt (engineer cron, v8). Prompt assembly stays in TS per ADR-003; the call routes through Rust call_anthropic per ADR-004.",
      "properties": {
        "type":           { "const": "dispatch-engineer" },
        "roleId":         { "type": "string", "description": "References ProjectManagerConfig.engineerRoles[].id on the same project." },
        "promptTemplate": { "type": "string", "description": "Raw prompt text. Variable substitution (e.g. {{branch}}, {{date}}) is deferred to a follow-up." },
        "modelOverride":  { "$ref": "#/definitions/modelFallbackEntry", "description": "Optional model override; falls back to role.primaryModel when absent." }
      },
      "required": ["type", "roleId", "promptTemplate"]
    },
    "modelFallbackEntry": {
      "type": "object",
      "properties": {
        "providerId": { "type": "string", "description": "LLM provider id, e.g. openai | anthropic | gemini | deepseek" },
        "modelId":    { "type": "string", "description": "Exact model identifier passed to the provider API" }
      },
      "required": ["providerId", "modelId"]
    },
    "engineerRole": {
      "type": "object",
      "properties": {
        "id":             { "type": "string" },
        "name":           { "type": "string" },
        "slug":           { "type": "string", "description": "Short identifier used in UI badges" },
        "skills":         { "type": "array", "items": { "type": "string" } },
        "commands":       { "type": "array", "items": { "type": "string" } },
        "systemPrompt":   { "type": "string", "description": "Prepended to AI dispatch prompts" },
        "referenceFiles": { "type": "array", "items": { "type": "string" }, "description": "Paths relative to project root" },
        "defaultAgentId": { "type": "string" },
        "notes":          { "type": "string" },
        "primaryModel":   { "$ref": "#/definitions/modelFallbackEntry", "description": "Primary LLM model for dispatches from this role" },
        "modelFallbacks": {
          "type": "array",
          "items": { "$ref": "#/definitions/modelFallbackEntry" },
          "description": "Ordered fallback chain tried when primaryModel fails (direct LLM calls only)"
        },
        "capabilities": {
          "type": "array",
          "description": "Capability assignments per role (schema v7). Each references a `passed` candidate from the matching sheet.",
          "items": { "$ref": "#/definitions/roleCapability" }
        },
        "browserAccess": {
          "$ref": "#/definitions/browserAccessPolicy",
          "description": "Browser allowlist for PM-mediated search/launch (schema v10, ADR-016). Absent = disabled."
        },
        "externalFileAccess": {
          "$ref": "#/definitions/externalFileAccessPolicy",
          "description": "External (non-project) directory access policy (schema v10, ADR-016). Absent = no external access."
        }
      },
      "required": ["id", "name", "slug", "skills", "commands", "systemPrompt", "referenceFiles"]
    },
    "browserAccessPolicy": {
      "type": "object",
      "description": "Which installed browsers an engineer may use (schema v10, ADR-016).",
      "properties": {
        "enabled": { "type": "boolean", "description": "Master switch. Default false — no browser access." },
        "allowedBrowserIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Allowed browser ids — subset of detected InstalledBrowser.id (e.g. macOS bundle ids)."
        }
      },
      "required": ["enabled", "allowedBrowserIds"]
    },
    "externalFileAccessPolicy": {
      "type": "object",
      "description": "External (non-project) directory access policy (schema v10, ADR-016).",
      "properties": {
        "entries": {
          "type": "array",
          "items": { "$ref": "#/definitions/externalFileAccessEntry" }
        },
        "requireConfirmForUnlisted": {
          "type": "boolean",
          "description": "Stored intent for a future runtime authorization prompt (L2b). Inert in v10."
        }
      },
      "required": ["entries", "requireConfirmForUnlisted"]
    },
    "externalFileAccessEntry": {
      "type": "object",
      "properties": {
        "path": { "type": "string", "description": "Absolute path to an external (non-project) directory." },
        "kind": { "type": "string", "enum": ["local-dir", "gdrive", "onedrive", "icloud", "other"] },
        "permission": { "type": "string", "enum": ["read", "write", "deny"], "description": "deny always wins over read/write." }
      },
      "required": ["path", "kind", "permission"]
    },
    "feature": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": {
          "type": "string",
          "description": "Feature grouping label. On the E2E testing phase, prefer: in_project, cross_project, external, smoke, regression, acceptance, migration, monitoring."
        },
        "status": {
          "type": "string",
          "enum": ["todo", "in_progress", "done", "on_hold"],
          "default": "todo"
        },
        "progress": { "type": "number", "minimum": 0, "maximum": 100 },
        "paths": {
          "type": "object",
          "description": "Source .md files are editable inputs; *Html variants are generated HTML report artifacts.",
          "properties": {
            "featureFolder": { "type": "string", "description": "Canonical feature folder: .project-manager/features/<ID>/" },
            "spec": { "type": "string", "description": "Feature dev spec (.md)" },
            "tdd": { "type": "string", "description": "TDD spec (.md)" },
            "tddProgressReport": { "type": "string", "description": "TDD progress raw data (.md)" },
            "tddProgressReportHtml": { "type": "string", "description": "TDD progress report (.html, generated)" },
            "debugRetro": { "type": "string", "description": "Debug retrospective (.md). Stores reproduction, root cause, fix, verification, and reusable lessons." },
            "testScenarios": { "type": "string", "description": "Test scenario map (.md). Translates real user paths into unit, integration, and E2E coverage candidates." },
            "unitIntegrationTest": { "type": "string", "description": "Unit & integration test path" },
            "e2eAcceptanceTestScriptFolder": { "type": "string", "description": "E2E acceptance test script folder" },
            "developmentLogSummaryFolder": { "type": "string", "description": "Raw dev log folder" },
            "devLogSummaryHtml": { "type": "string", "description": "Dev log summary (.html, generated)" },
            "test": { "type": "string", "description": "Test script path" },
            "implementation": { "type": "string", "description": "Implementation code path" }
          }
        },
        "notes": { "type": "string", "description": "Path to .project-manager/features/<ID>/notes.md. Free-form markdown; leave as empty string if no notes file exists." },
        "readmePath": { "type": "string", "description": "Relative path to the feature overview README (e.g. .project-manager/features/F01/README.md)." },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the feature was first created (v2)."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp bumped on every modification (v2)."
        },
        "updatedBy": {
          "type": "string",
          "description": "Identifier of the last editor — e.g. GitHub login or email (v2)."
        },
        "phase": {
          "type": "string",
          "enum": ["development", "e2e_testing", "deployment", "operations"],
          "default": "development",
          "description": "Lifecycle phase (v3)."
        },
        "points": {
          "type": "number",
          "minimum": 0,
          "description": "Story-point weight (v3); defaults to 1 in aggregations."
        },
        "locatedSection": {
          "type": "string",
          "description": "Section, area, or route where the feature lives (v6)."
        },
        "upstreamDependencies": {
          "type": "array",
          "description": "Feature dependency refs used for dispatch planning (v9). Persist upstream only; downstream is derived.",
          "items": { "$ref": "#/definitions/featureDependencyRef" }
        },
        "testCoverage": { "type": "number", "minimum": 0, "maximum": 100 },
        "testStatus": { "type": "string", "enum": ["passed", "failed", "pending"] },
        "deployStatus": { "type": "string", "enum": ["production", "staging", "not_deployed"] },
        "deployEnv": { "type": "string" },
        "deployDate": { "type": "string" },
        "uptimePercent": { "type": "number", "minimum": 0, "maximum": 100 },
        "errorRate": { "type": "number", "minimum": 0 },
        "avgResponseTime": { "type": "number", "minimum": 0 },
        "lastIncident": { "type": "string" },
        "tddProgress": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "TDD-specific progress percentage, distinct from overall feature progress."
        },
        "assignedRoleId": {
          "type": "string",
          "description": "Per-feature assigned engineerRole id (references engineerRoles[].id)."
        },
        "assignedIDE": {
          "type": "string",
          "enum": ["Cursor", "VSCode", "Trae", "Antigravity", "Kiro"],
          "description": "Per-feature IDE override; falls back to project.defaultIDE when unset."
        },
        "assignedTo": {
          "type": "string",
          "description": "Active developer or agent identifier set at dispatch time (e.g. adapter name)."
        },
        "assignedAt": {
          "type": "string",
          "description": "ISO 8601 timestamp when the task was claimed via dispatch."
        },
        "harnessAssignments": {
          "type": "object",
          "description": "Optional multi-role assignments for harness-style workflows (Planner / Worker / Evaluator).",
          "properties": {
            "planner": { "$ref": "#/definitions/featureHarnessAssignment" },
            "worker": { "$ref": "#/definitions/featureHarnessAssignment" },
            "evaluator": { "$ref": "#/definitions/featureHarnessAssignment" }
          }
        },
        "acceptanceChecklist": {
          "type": "array",
          "items": { "$ref": "#/definitions/featureAcceptanceChecklistItem" }
        },
        "promptConfig": {
          "type": "object",
          "description": "Auto-loop prompt config (v3).",
          "properties": {
            "body":          { "type": "string" },
            "agentId":       { "type": "string" },
            "modelProviderId": { "type": "string" },
            "modelId":       { "type": "string" },
            "lastDispatchModel": { "type": "string", "description": "providerId/modelId of the model that actually ran last, e.g. openai/gpt-5.5" },
            "autoLoop":      { "type": "boolean" },
            "stopCondition": { "type": "string" },
            "maxIterations": { "type": "integer", "minimum": 1 },
            "workingDir":    { "type": "string" }
          }
        }
      },
      "required": ["id", "name", "category", "status", "progress", "paths"]
    },
    "featureDependencyRef": {
      "type": "object",
      "properties": {
        "projectId": {
          "type": "string",
          "description": "Optional dashboard project id. Required when multiple selected projects share the same feature id."
        },
        "featureId": {
          "type": "string",
          "description": "Human-readable feature id such as F37. Do not store the technical UUID table id here."
        },
        "kind": {
          "type": "string",
          "enum": ["hard", "soft"],
          "description": "Hard dependencies block dispatch until done; soft dependencies warn only. Defaults to hard."
        },
        "reason": {
          "type": "string",
          "description": "Optional human-authored dependency reason."
        }
      },
      "required": ["featureId"]
    },
    "featureHarnessAssignment": {
      "type": "object",
      "properties": {
        "engineerRoleId": { "type": "string" },
        "assignedIDE": { "type": "string", "enum": ["Cursor", "VSCode", "Trae", "Antigravity", "Kiro"] },
        "assignedTo": { "type": "string" },
        "assignedAt": { "type": "string" },
        "adapterId": { "type": "string" },
        "lastDispatchModel": { "type": "string" }
      }
    },
    "featureAcceptanceChecklistItem": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "passes": { "type": "boolean" }
      },
      "required": ["id", "description", "passes"]
    },
    "capabilityKind": {
      "type": "string",
      "enum": ["eyes", "voice-tts", "voice-stt", "hands", "recording"],
      "description": "Top-level capability kinds an engineer role may request (schema v7)."
    },
    "adapterTrait": {
      "type": "string",
      "enum": ["direct-access"],
      "description": "Optional adapter trait flags that bend dependency rules (schema v7)."
    },
    "candidateSheet": {
      "type": "string",
      "enum": ["vla", "tts", "stt", "hands", "tools"],
      "description": "Which Integrations Hub sheet a candidate lives in (schema v7)."
    },
    "candidateState": {
      "type": "string",
      "enum": ["not_tested", "testing", "passed", "passed_disabled", "failed"],
      "description": "Lifecycle state of a single capability candidate (schema v7)."
    },
    "candidateRef": {
      "type": "object",
      "properties": {
        "sheet": { "$ref": "#/definitions/candidateSheet" },
        "id":    { "type": "string" }
      },
      "required": ["sheet", "id"]
    },
    "capabilityCandidate": {
      "type": "object",
      "properties": {
        "id":            { "type": "string" },
        "sheet":         { "$ref": "#/definitions/candidateSheet" },
        "label":         { "type": "string" },
        "providerId":    { "type": "string" },
        "modelId":       { "type": "string" },
        "state":         { "$ref": "#/definitions/candidateState" },
        "lastTestedAt":  { "type": "string", "format": "date-time" },
        "lastTestResult": {
          "type": "object",
          "properties": {
            "ok":         { "type": "boolean" },
            "durationMs": { "type": "number", "minimum": 0 },
            "message":    { "type": "string" }
          },
          "required": ["ok", "durationMs", "message"]
        },
        "requires": {
          "type": "array",
          "items": { "$ref": "#/definitions/candidateRef" }
        },
        "config": { "type": "object" }
      },
      "required": ["id", "sheet", "label", "state"]
    },
    "roleCapability": {
      "type": "object",
      "properties": {
        "kind":        { "$ref": "#/definitions/capabilityKind" },
        "candidateId": { "type": "string" },
        "config": {
          "type": "object",
          "properties": {
            "ttsVoice":             { "type": "string" },
            "sttCorrectionModelId": { "type": "string" },
            "handsConfirmMode":     { "type": "string", "enum": ["per-action", "session-trust"] },
            "handsRequiresEyes":    { "type": "boolean" },
            "recordingDir":         { "type": "string" }
          }
        }
      },
      "required": ["kind", "candidateId"]
    }
  }
}
