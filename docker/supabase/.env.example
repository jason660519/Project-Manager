############
# Local Supabase (Project Manager) — copy to .env and adjust if needed.
#   cp .env.example .env
#   docker compose up -d --build
############

COMPOSE_FILE=docker-compose.yml

# Postgres
POSTGRES_PASSWORD=postgres-dev-password-change-me
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# Legacy symmetric HS256 JWT (local dev only)
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

